# ---------------------------------------------------------------------------
# .gitignore — tells git which files to NEVER track or commit.
#
# Git is version control software that tracks changes to your code.
# Some files should NEVER be committed to git because they contain:
#   - Passwords and secrets (security risk if the repo is public)
#   - Temporary files (noise in the code history)
#   - Generated files (can be recreated, no need to track)
#
# Any file matching a pattern below will be invisible to git.
# ---------------------------------------------------------------------------

# Secrets — written by CI on the server, never committed.
# This folder contains the DATABASE_URL file with the Postgres password.
secrets/

# Bootstrap secrets — written locally by scripts/new-service.sh on first run.
# Contains the generated POSTGRES_PASSWORD and REPLICATION_PASSWORD.
# This MUST stay gitignored permanently. We learned the hard way: if a
# service forked from this template re-syncs via rsync without preserving
# the gitignore, these secrets get committed to a public repo.
.bootstrap-secrets/

# Python bytecode files — generated when Python runs your code.
# They're cached versions of .py files for faster loading. Regenerated
# automatically, no need to track them.
__pycache__/
*.pyc
*.pyo
*.egg-info/

# Python virtual environments — folders containing installed packages
# for local development. Each developer creates their own.
.venv/
venv/

# Editor and OS files — generated by your code editor or operating system.
# These are personal preferences, not part of the project.
.DS_Store     # macOS folder metadata
.idea/        # JetBrains IDE (PyCharm) settings
.vscode/      # VS Code settings
*.swp         # Vim swap files (temporary editor backups)
