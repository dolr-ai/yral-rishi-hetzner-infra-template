# project.config — single source of truth for ALL project-specific values.
#
# A new project edits THIS FILE; nothing else. Every other file references
# these vars via ${VAR} interpolation.
#
# Sourced by:
#   - local/setup.sh (with `set -a; source ../project.config; set +a`)
#   - scripts/ci/deploy-db-stack.sh (same pattern, on the server)
#   - scripts/ci/deploy-app.sh (same pattern, on the server)
#   - .github/workflows/deploy.yml (parsed into $GITHUB_ENV at the start of each job)
#
# IMPORTANT: every value below MUST be a simple `KEY=value` line — no spaces
# around `=`, no comments on the same line as a value (otherwise the bash
# `source` command and the GitHub Actions `>> $GITHUB_ENV` parse will choke).

# The bare project name (used as the subdomain prefix and as the suffix of
# many other identifiers below). Lowercase, alphanumeric, hyphens.
PROJECT_NAME=rishi-hetzner-infra-template

# The full public domain (becomes the host in caddy/snippet.caddy.template)
PROJECT_DOMAIN=rishi-hetzner-infra-template.rishi.yral.com

# The repo / image name (everything dolr-ai uses gets a `yral-` prefix)
PROJECT_REPO=yral-rishi-hetzner-infra-template

# Postgres database name (must use underscores, not hyphens, per Postgres rules)
POSTGRES_DB=rishi_hetzner_infra_template_db

# Patroni cluster scope — namespaces this project's Patroni cluster in etcd
# so it cannot collide with another project's Patroni on the same Swarm
PATRONI_SCOPE=rishi-hetzner-infra-template-cluster

# etcd cluster token — same isolation reason as PATRONI_SCOPE
ETCD_TOKEN=rishi-hetzner-infra-template-etcd-cluster

# Docker Swarm stack name (must be globally unique within the Swarm cluster)
SWARM_STACK=rishi-hetzner-infra-template-db

# Per-project overlay network name (Docker Swarm scope; isolates DB traffic)
OVERLAY_NETWORK=rishi-hetzner-infra-template-db-internal

# Image references (GHCR org is fixed; everything after the slash is the project)
IMAGE_REPO=ghcr.io/dolr-ai/yral-rishi-hetzner-infra-template
PATRONI_IMAGE_REPO=ghcr.io/dolr-ai/yral-rishi-hetzner-infra-template-patroni

# Set to "false" for stateless services (e.g. ML inference) that don't need
# Postgres. When false, CI skips the deploy-db-stack job entirely and the
# app must not reference DATABASE_URL. Run `bash scripts/strip-database.sh`
# once to physically remove etcd/, patroni/, haproxy/, and DB-related files.
WITH_DATABASE=true
